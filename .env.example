# DAV Monitor - Environment variables (copy to .env and fill values)

# Gmail sender (create App Password at https://myaccount.google.com/apppasswords)
SENDER_EMAIL=your_gmail@gmail.com
SENDER_PASSWORD=xxxx xxxx xxxx xxxx

# Recipient
RECIPIENT_EMAIL=nguyetlan289@gmail.com

# SMTP (Gmail defaults)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# OpenAI API key (optional - get at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Data paths (optional, defaults shown)
DB_PATH=data/dav_history.db
DOWNLOAD_DIR=data/downloads
LOG_PATH=data/monitor.log
